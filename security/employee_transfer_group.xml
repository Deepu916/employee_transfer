<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="employee_transfer_group_category" model="ir.module.category">
        <field name="name">Employee Transfer</field>
        <field name="sequence">15</field>
    </record>

    <record id="employee_transfer_group_privilege" model="res.groups.privilege">
        <field name="name">Employee Transfer Access</field>
        <field name="category_id" ref="employee_transfer_group_category"/>
    </record>

    <record id="employee_group" model="res.groups">
        <field name="name">Employee</field>
        <field name="privilege_id" ref="employee_transfer_group_privilege"/>
    </record>

    <record id="admin_group" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="employee_transfer_group_privilege"/>
        <field name="implied_ids" eval="[(4,ref('base.group_system'))]"/>
        <field name="user_ids" eval="[(4,ref('base.user_admin'))]"/>
    </record>
</odoo>